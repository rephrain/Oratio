# ============================================
# Oratio Dental — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Database
DATABASE_URL=postgresql://oratio:your_password@localhost:5432/oratio
POSTGRES_PASSWORD=your_secure_password

# JWT Authentication
JWT_SECRET=your-secure-jwt-secret-here

# SatuSehat API
# Set to 'production' for live data, 'staging' for testing
SATUSEHAT_ENV=staging
SATUSEHAT_CLIENT_ID=your_client_id
SATUSEHAT_CLIENT_SECRET=your_client_secret
SATUSEHAT_ORG_ID=your_org_id

# SatuSehat Base URLs (staging defaults)
BASE_URL=https://api-satusehat-stg.dto.kemkes.go.id/fhir-r4/v1
AUTH_URL=https://api-satusehat-stg.dto.kemkes.go.id/oauth2/v1

# Snowstorm SNOMED-CT
SNOWSTORM_BASE_URL=https://snowstorm.ihtsdotools.org/fhir/ValueSet/

# App Configuration
PORT=3000
HOST=0.0.0.0
