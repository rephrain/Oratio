        end
    end

    subgraph "External APIs"
        SS["SatuSehat API<br/>(Staging/Production)"]
        SNOW["Snowstorm<br/>SNOMED-CT Server"]
    end

    BROWSER["Browser (LAN)"] --> APP
    APP --> DB
    APP --> SS
    APP --> SNOW
```

